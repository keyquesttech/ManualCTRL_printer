[Unit]
Description=Polar 3D Printer Host
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/ManualCTRL_printer
Environment=SERIAL_PORT=/dev/ttyACM0
Environment=SERIAL_BAUD=115200
ExecStart=/home/pi/ManualCTRL_printer/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
